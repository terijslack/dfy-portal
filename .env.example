# Copy this file to .env and fill in your real values
# NEVER commit your actual .env file to GitHub

# Get this from Railway → your Postgres service → Variables tab
DATABASE_URL=postgresql://user:password@host:port/dbname

# Make up any long random string — this signs your login tokens
JWT_SECRET=make-this-long-and-random-like-this-abc123xyz789

# Railway sets this automatically — leave as 3000 locally
PORT=3000

# Get this from buffer.com → Settings → API → Access Token
BUFFER_ACCESS_TOKEN=your-buffer-token-here

# Your Buffer profile IDs (get from Buffer API or dashboard URL)
# Comma-separated if multiple: id1,id2
BUFFER_PROFILE_IDS=your-buffer-profile-id-here
